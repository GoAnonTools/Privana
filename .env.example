# ── Privana environment ───────────────────────────────────────────────────────
# Use "development" locally and "production" on the VPS.
ENVIRONMENT=development

# Flask sessions, CSRF, signed QR/config tokens.
# Generate with:
# python3 - <<'PY'
# import secrets
# print(secrets.token_urlsafe(64))
# PY
SECRET_KEY=CHANGE_ME
SECURITY_PASSWORD_SALT=CHANGE_ME

# Local HTTP dev should be false.
# Production behind HTTPS should be true.
SESSION_COOKIE_SECURE=false

# ── Anonymous admin account ──────────────────────────────────────────────────
# Optional. Set this to the 16-digit anonymous account number that should access
# admin-only health/status routes.
ADMIN_ACCOUNT=1234567890123456

# ── WireGuard client config values ───────────────────────────────────────────
# Public key of the WireGuard server.
WG_SERVER_PUBLIC_KEY=CHANGE_ME

# Public VPN endpoint shown in generated client configs.
# Example: vpn.privana.pro:51820
WG_SERVER_ENDPOINT=vpn.yourdomain.com:51820

# DNS servers pushed to WireGuard clients.
WG_DNS=1.1.1.1, 1.0.0.1

# ── Internal Privana VPN API ─────────────────────────────────────────────────
# This is NOT a third-party API key.
# API_SECRET is the shared HMAC secret used between the Privana web app and
# Privana's own server/api.py service.
VPN_API_BASE=http://127.0.0.1:8080
API_SECRET=CHANGE_ME

# ── Local desktop helper ─────────────────────────────────────────────────────
# Shared token between the browser dashboard and the local Windows helper.
# Required so random websites cannot control the local WireGuard helper.
PRIVANA_HELPER_TOKEN=CHANGE_ME

# Optional helper CORS origins for local Windows helper.
# Keep this strict.
PRIVANA_ALLOWED_ORIGINS=http://127.0.0.1:5000,http://localhost:5000

# ── Optional paths ───────────────────────────────────────────────────────────
# SQLite nonce replay-protection DB for server/api.py.
# Default: server/nonces.db
# NONCE_DB_PATH=/absolute/path/to/nonces.db

# Trust X-Forwarded-For / X-Real-IP only when behind a trusted reverse proxy.
# Keep false for local/dev and direct exposure.
TRUST_PROXY_HEADERS=false
# ── WebAuthn / passkeys ──────────────────────────────────────────────────────
# Local development:
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5000

# Production example:
# WEBAUTHN_RP_ID=privana.pro
# WEBAUTHN_ORIGIN=https://privana.pro
