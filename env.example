# ── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME                        # openssl rand -hex 32
SECURITY_PASSWORD_SALT=CHANGE_ME           # openssl rand -hex 32
ENVIRONMENT=production                     # set to "development" locally
SESSION_COOKIE_SECURE=true                 # set to false only for local http dev

# ── Admin ────────────────────────────────────────────────────────────────────
ADMIN_ACCOUNT=1234567890123456             # 16-digit account number of the admin user

# ── WireGuard (web → VPN server) ─────────────────────────────────────────────
WG_SERVER_PUBLIC_KEY=CHANGE_ME             # output of: wg pubkey < /etc/wireguard/server_private.key
WG_SERVER_ENDPOINT=vpn.yourdomain.com:51820
WG_DNS=1.1.1.1, 1.0.0.1

# ── VPN server API ───────────────────────────────────────────────────────────
VPN_API_BASE=http://127.0.0.1:8080         # base URL of the server/api.py service
API_SECRET=CHANGE_ME                       # must match API_SECRET in server .env

# ── Mail (magic links) ───────────────────────────────────────────────────────
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password

# ── Dev helpers (never set these in production) ───────────────────────────────
# DEV_ECHO_LINKS=true                      # print magic links to flash + stdout
